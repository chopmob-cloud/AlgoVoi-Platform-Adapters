<div class="algovoi-payment-panel" style="
  background:#141622;
  border:1px solid #1f2235;
  border-radius:10px;
  padding:20px 22px;
  color:#e0e0e0;
  font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;
  margin-bottom:16px;
">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;">
    <div style="display:flex;align-items:center;gap:10px;">
      <span style="width:28px;height:28px;border-radius:7px;background:linear-gradient(135deg,#6366f1,#8b5cf6);
                   display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0;">&#9670;</span>
      <strong style="color:#fff;font-size:15px;font-weight:700;">AlgoVoi</strong>
      <span style="font-size:11px;color:#6b7280;border:1px solid #1f2235;border-radius:4px;padding:2px 7px;">Hosted</span>
    </div>
    <div style="display:flex;gap:6px;">
      <span style="font-size:10px;background:rgba(99,102,241,.1);color:#818cf8;border-radius:4px;padding:2px 7px;font-weight:600;">Secure checkout</span>
      <span style="font-size:10px;background:rgba(245,158,11,.1);color:#fbbf24;border-radius:4px;padding:2px 7px;font-weight:600;">Redirect</span>
    </div>
  </div>

  <p style="margin:0 0 14px;font-size:12.5px;color:#9ca3af;line-height:1.6;">
    Pay with USDC / aUSDC / USDCe stablecoins via hosted checkout. You will be redirected after confirming your order.
  </p>

  {% if enabled_networks|length == 1 %}
    {% for value, label in enabled_networks %}
      <input type="hidden" name="algovoi_network" id="algovoi_network_hidden" value="{{ value }}">
      <div style="margin-bottom:16px;display:flex;align-items:center;gap:.6rem;">
        <span id="av-dot" style="display:inline-block;width:10px;height:10px;border-radius:50%;flex-shrink:0;
                                  background:{{ value == 'voi_mainnet' ? '#8b5cf6' : (value == 'hedera_mainnet' ? '#10b981' : (value == 'stellar_mainnet' ? '#06b6d4' : (value == 'tempo_mainnet' ? '#f59e0b' : '#3b82f6'))) }};"></span>
        <span style="font-size:13px;color:#e0e0e0;">{{ label|raw }}</span>
      </div>
    {% endfor %}
  {% else %}
    <div style="margin-bottom:16px;">
      <label for="algovoi_network_select"
             style="display:block;font-size:11px;font-weight:700;text-transform:uppercase;
                    letter-spacing:.06em;color:#6b7280;margin-bottom:6px;">Select network</label>
      <div style="display:flex;align-items:center;gap:.6rem;">
        <span id="av-dot" style="display:inline-block;width:10px;height:10px;border-radius:50%;
                                  background:#3b82f6;flex-shrink:0;transition:background .2s;"></span>
        <div style="position:relative;flex:1;">
          <select id="algovoi_network_select"
                  name="algovoi_network"
                  style="width:100%;padding:.5rem .75rem;background:#0d0e1a;border:1px solid #2a2d3a;
                         border-radius:7px;color:#f1f2f6;font-size:.88rem;cursor:pointer;
                         appearance:none;-webkit-appearance:none;outline:none;transition:border-color .2s;"
                  onfocus="this.style.borderColor='#6366f1'"
                  onblur="this.style.borderColor='#2a2d3a'"
                  onchange="(function(v){var m={'algorand_mainnet':'#3b82f6','voi_mainnet':'#8b5cf6','hedera_mainnet':'#10b981','stellar_mainnet':'#06b6d4','base_mainnet':'#2563eb','solana_mainnet':'#9333ea','tempo_mainnet':'#f59e0b'};document.getElementById('av-dot').style.background=m[v]||'#3b82f6';})(this.value)">
            {% for value, label in enabled_networks %}
              <option value="{{ value }}">{{ label|raw }}</option>
            {% endfor %}
          </select>
          <span style="position:absolute;right:.7rem;top:50%;transform:translateY(-50%);
                       color:#6b7280;pointer-events:none;font-size:.75rem;">&#9662;</span>
        </div>
      </div>
    </div>
  {% endif %}

  <div class="text-end" style="margin-bottom:12px;">
    <button type="button" id="button-algovoi-confirm" class="btn btn-primary"
            style="padding:.55rem 1.4rem;font-size:.9rem;">
      Confirm Order
    </button>
  </div>

  <div style="padding-top:.65rem;border-top:1px solid #1f2235;
              display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.4rem;">
    <span style="font-size:.72rem;color:#4b5563;">
      Secured by
      <a href="https://www.algovoi.co.uk" target="_blank" rel="noopener"
         style="color:#6366f1;text-decoration:none;font-weight:600;">AlgoVoi</a>
      &mdash; instant on-chain settlement
    </span>
    <span style="font-size:.72rem;color:#374151;">No chargebacks &bull; No FX fees</span>
  </div>
</div>

<script type="text/javascript">
$('#button-algovoi-confirm').on('click', function() {
    var element = this;
    $(element).prop('disabled', true).text('Redirecting...');

    var network = $('#algovoi_network_select').val()
               || $('#algovoi_network_hidden').val()
               || 'algorand_mainnet';

    $.ajax({
        url: 'index.php?route=extension/algovoi/payment/algovoi.confirm&language={{ language }}',
        type: 'POST',
        data: { algovoi_network: network },
        dataType: 'json',
        success: function(json) {
            if (json['error']) {
                $('#alert').prepend('<div class="alert alert-danger alert-dismissible"><i class="fa-solid fa-circle-exclamation"></i> ' + json['error'] + ' <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>');
                $(element).prop('disabled', false).text('Confirm Order');
            }
            if (json['redirect']) {
                location = json['redirect'];
            }
        },
        error: function(xhr) {
            console.log(xhr.responseText);
            $(element).prop('disabled', false).text('Confirm Order');
        }
    });
});
</script>
