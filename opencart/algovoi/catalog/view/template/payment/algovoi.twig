<div class="algovoi-payment-panel" style="
  background:#0d0d0d;
  border:1px solid #2a2d3a;
  border-radius:8px;
  padding:20px 24px;
  color:#e0e0e0;
  font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;
  margin-bottom:16px;
">
  <div style="display:flex;align-items:center;gap:12px;margin-bottom:12px;">
    <strong style="color:#fff;font-size:16px;">AlgoVoi</strong>
    <span style="color:#666;font-size:13px;">On-chain crypto payment</span>
  </div>
  <p style="margin:0 0 14px;font-size:13px;color:#aaa;line-height:1.5;">
    Pay with USDC stablecoins via hosted checkout. You will be redirected after confirming your order.
  </p>

  {% if enabled_networks|length == 1 %}
    {# Single network — no visible selector #}
    {% for value, label in enabled_networks %}
      <input type="hidden" name="algovoi_network" value="{{ value }}">
      <p style="margin:0 0 14px;font-size:12px;color:#666;">Network: <span style="color:#e0e0e0;">{{ label|raw }}</span></p>
    {% endfor %}
  {% else %}
    <div style="margin-bottom:16px;">
      <label for="algovoi_network_select"
             style="display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:#666;margin-bottom:8px;">
        Select network
      </label>
      <select id="algovoi_network_select"
              name="algovoi_network"
              style="width:100%;padding:.45rem .7rem;background:#1a1a2e;border:1px solid #2a2d3a;border-radius:6px;color:#e0e0e0;font-size:13px;">
        {% for value, label in enabled_networks %}
          <option value="{{ value }}">{{ label|raw }}</option>
        {% endfor %}
      </select>
    </div>
  {% endif %}

  <div class="text-end">
    <button type="button" id="button-algovoi-confirm" class="btn btn-primary">Confirm Order</button>
  </div>
</div>

<script type="text/javascript">
$('#button-algovoi-confirm').on('click', function() {
    var element = this;
    $(element).prop('disabled', true).text('Redirecting...');

    var network = $('select[name="algovoi_network"]').val()
               || $('input[name="algovoi_network"]').val()
               || 'algorand_mainnet';

    $.ajax({
        url: 'index.php?route=extension/algovoi/payment/algovoi.confirm&language={{ language }}',
        type: 'POST',
        data: { algovoi_network: network },
        dataType: 'json',
        success: function(json) {
            if (json['error']) {
                $('#alert').prepend('<div class="alert alert-danger alert-dismissible"><i class="fa-solid fa-circle-exclamation"></i> ' + json['error'] + ' <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>');
                $(element).prop('disabled', false).text('Confirm Order');
            }
            if (json['redirect']) {
                location = json['redirect'];
            }
        },
        error: function(xhr) {
            console.log(xhr.responseText);
            $(element).prop('disabled', false).text('Confirm Order');
        }
    });
});
</script>
