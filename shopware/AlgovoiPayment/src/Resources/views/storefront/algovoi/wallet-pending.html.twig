{% sw_extends '@Storefront/storefront/base.html.twig' %}

{% block base_main_inner %}
<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card text-center p-4" style="background:#1a1f2e;border-color:#2d3748;">
                <h2 class="mb-3" style="color:#e2e8f0;">Pay with AlgoVoi Wallet</h2>
                <p style="color:#94a3b8;">Amount: <strong style="color:#e2e8f0;">{{ amountDisplay }} {{ ticker }}</strong></p>
                <p style="color:#94a3b8;font-size:.85rem;word-break:break-all;">To: {{ receiver }}</p>
                <p style="color:#64748b;font-size:.8rem;">Memo: {{ memo }}</p>

                <div id="algovoi-status" class="alert alert-info my-3" style="display:none;"></div>

                <button id="algovoi-pay-btn"
                        class="btn btn-primary w-100 mt-3"
                        style="background:#3b82f6;border-color:#3b82f6;font-size:1rem;">
                    Connect Wallet &amp; Pay
                </button>
                <p class="mt-3" style="color:#64748b;font-size:.8rem;">
                    Requires Pera, Defly, or Lute wallet browser extension.
                </p>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/algosdk@3/dist/browser/algosdk.min.js"></script>
<script>
(function () {
    var ALGOD_URL  = {{ algodUrl|json_encode|raw }};
    var ASSET_ID   = {{ assetId }};
    var AMOUNT_MU  = {{ amountMu }};
    var RECEIVER   = {{ receiver|json_encode|raw }};
    var MEMO       = {{ memo|json_encode|raw }};
    var TX_ID      = {{ txId|json_encode|raw }};
    var RETURN_URL = {{ returnUrl|json_encode|raw }};

    var btn    = document.getElementById('algovoi-pay-btn');
    var status = document.getElementById('algovoi-status');

    function showStatus(msg, type) {
        status.className = 'alert alert-' + (type || 'info') + ' my-3';
        status.textContent = msg;
        status.style.display = 'block';
    }

    btn.addEventListener('click', async function () {
        btn.disabled = true;
        showStatus('Connecting wallet\u2026', 'info');

        try {
            if (!window.algorand) {
                throw new Error('No wallet extension detected. Please install Pera, Defly, or Lute.');
            }

            var enableResult = await window.algorand.enable();
            var sender = enableResult.accounts[0];
            if (!sender) throw new Error('No account returned from wallet.');

            showStatus('Building transaction\u2026', 'info');

            var algodClient = new algosdk.Algodv2('', ALGOD_URL, '');
            var params = await algodClient.getTransactionParams().do();

            var enc = new TextEncoder();
            var txn = algosdk.makeAssetTransferTxnWithSuggestedParamsFromObject({
                sender:          sender,
                receiver:        RECEIVER,
                assetIndex:      ASSET_ID,
                amount:          AMOUNT_MU,
                note:            enc.encode(MEMO),
                suggestedParams: params,
            });

            var txnBytes = algosdk.encodeUnsignedTransaction(txn);
            var b64Txn   = btoa(String.fromCharCode.apply(null, txnBytes));

            showStatus('Please approve in your wallet\u2026', 'info');

            var signResult = await window.algorand.signTransactions([{ txn: b64Txn }]);

            var signedB64 = Array.isArray(signResult.stxns)
                ? signResult.stxns[0]
                : (signResult[0] || null);

            if (!signedB64) throw new Error('No signed transaction returned from wallet.');

            showStatus('Submitting to network\u2026', 'info');

            var signedBytes = Uint8Array.from(atob(signedB64), function(c) { return c.charCodeAt(0); });
            var submitResp  = await fetch(ALGOD_URL + '/v2/transactions', {
                method:  'POST',
                headers: { 'Content-Type': 'application/x-binary' },
                body:    signedBytes,
            });
            var submitBody = await submitResp.json();
            if (!submitResp.ok) throw new Error(submitBody.message || 'Transaction submission failed.');

            var txHash = submitBody.txId || submitBody['tx-hash'] || submitBody.txid;
            if (!txHash) throw new Error('No transaction ID in algod response.');

            showStatus('Waiting for on-chain confirmation\u2026', 'info');

            // Wait for the transaction to be confirmed before verifying
            await algosdk.waitForConfirmation(algodClient, txHash, 10);

            showStatus('Verifying payment\u2026', 'info');

            var verifyResp = await fetch('/algovoi/verify', {
                method:  'POST',
                headers: { 'Content-Type': 'application/json' },
                body:    JSON.stringify({ txId: TX_ID, tx_id: txHash }),
            });
            var verifyBody = await verifyResp.json();

            if (verifyBody.success) {
                showStatus('Payment confirmed! Redirecting\u2026', 'success');
                setTimeout(function () { window.location.href = verifyBody.returnUrl || RETURN_URL; }, 1500);
            } else {
                throw new Error(verifyBody.error || 'Verification failed.');
            }

        } catch (err) {
            showStatus(err.message || 'An error occurred.', 'danger');
            btn.disabled = false;
        }
    });
})();
</script>
{% endblock %}
