{% sw_extends '@Storefront/storefront/page/checkout/confirm/confirm-payment.html.twig' %}

{% block page_checkout_change_payment_form %}
    {{ parent() }}

    {# ── Resolve real payment method UUIDs from handlerIdentifier ─────────── #}
    {% set _hostedHandler = 'AlgovoiPayment\\\\PaymentHandler\\\\AlgovoiHostedPaymentHandler' %}
    {% set _walletHandler = 'AlgovoiPayment\\\\PaymentHandler\\\\AlgovoiWalletPaymentHandler' %}
    {% set _hostedId = '' %}
    {% set _walletId = '' %}
    {% for pm in page.paymentMethods %}
        {% if pm.handlerIdentifier == _hostedHandler %}{% set _hostedId = pm.id %}{% endif %}
        {% if pm.handlerIdentifier == _walletHandler %}{% set _walletId = pm.id %}{% endif %}
    {% endfor %}

    {# ── Build enabled-networks list from system config ─────────────────────── #}
    {% set _allNetworks = {
        'algorand_mainnet': 'Algorand — USDC',
        'voi_mainnet':      'VOI — aUSDC',
        'hedera_mainnet':   'Hedera — USDC',
        'stellar_mainnet':  'Stellar — USDC',
        'base_mainnet':     'Base — USDC',
        'solana_mainnet':   'Solana — USDC',
        'tempo_mainnet':    'Tempo — USDCe'
    } %}
    {% set _cfgEnabled = config('AlgovoiPayment.config.enabledNetworks') %}
    {% if _cfgEnabled is iterable and _cfgEnabled is not empty %}
        {% set _enabledKeys = _cfgEnabled %}
    {% else %}
        {% set _enabledKeys = _allNetworks|keys %}
    {% endif %}
    {% set _walletKeys = ['algorand_mainnet', 'voi_mainnet'] %}

    {% set _hostedJson = [] %}
    {% for k in _enabledKeys %}
        {% if _allNetworks[k] is defined %}
            {% set _hostedJson = _hostedJson|merge([{'value': k, 'label': _allNetworks[k]}]) %}
        {% endif %}
    {% endfor %}
    {% set _walletJson = [] %}
    {% for k in _walletKeys %}
        {% set _walletJson = _walletJson|merge([{'value': k, 'label': _allNetworks[k]}]) %}
    {% endfor %}

    <script>
    (function() {
        var HOSTED_ID = '{{ _hostedId|e('js') }}';
        var WALLET_ID = '{{ _walletId|e('js') }}';

        var hostedChains = {{ _hostedJson|json_encode|raw }};
        var walletChains = {{ _walletJson|json_encode|raw }};

        var NET_COLOURS = {
            algorand_mainnet: '#3b82f6',
            voi_mainnet:      '#8b5cf6',
            hedera_mainnet:   '#10b981',
            stellar_mainnet:  '#06b6d4',
            base_mainnet:     '#2563eb',
            solana_mainnet:   '#9333ea',
            tempo_mainnet:    '#f59e0b'
        };

        // Persist user's chain pick across AJAX re-renders of the payment method list
        // (Shopware's data-form-auto-submit on changePaymentForm wipes the .payment-method divs)
        var userChain = null;
        var rendering = false;

        function escAttr(s) {
            return String(s).replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;');
        }

        function buildPanel(chains, isWallet) {
            var badge1 = isWallet
                ? '<span style="font-size:11px;background:rgba(59,130,246,.1);color:#60a5fa;border-radius:4px;padding:2px 6px;font-weight:600;">In-page</span>'
                + '<span style="font-size:11px;background:rgba(16,185,129,.1);color:#34d399;border-radius:4px;padding:2px 6px;font-weight:600;">No redirect</span>'
                : '<span style="font-size:11px;background:rgba(99,102,241,.1);color:#818cf8;border-radius:4px;padding:2px 6px;font-weight:600;">Secure checkout</span>'
                + '<span style="font-size:11px;background:rgba(245,158,11,.1);color:#fbbf24;border-radius:4px;padding:2px 6px;font-weight:600;">Redirect</span>';
            var badgeType = isWallet ? 'Extension' : 'Hosted';

            // Default selected chain: previous user pick if still valid, else chains[0]
            var defaultChain = chains[0].value;
            if (userChain && chains.some(function(c) { return c.value === userChain; })) {
                defaultChain = userChain;
            }
            var firstColour = NET_COLOURS[defaultChain] || '#3b82f6';

            var selectorHtml = '';
            if (chains.length === 1) {
                // Single chain — hidden input tied to confirmOrderForm via form="..."
                selectorHtml = '<div style="margin-bottom:8px;display:flex;align-items:center;gap:.5rem;">'
                    + '<span id="av-sw-dot" style="display:inline-block;width:9px;height:9px;border-radius:50%;flex-shrink:0;background:' + firstColour + ';"></span>'
                    + '<span style="font-size:.85rem;color:#e0e0e0;">' + escAttr(chains[0].label) + '</span>'
                    + '<input type="hidden" name="algovoi_network" form="confirmOrderForm" value="' + escAttr(chains[0].value) + '">'
                    + '</div>';
            } else {
                // Multi-chain: <select> attached to confirmOrderForm via form="confirmOrderForm"
                // (browser will include this select in the order submission regardless of DOM nesting)
                var opts = chains.map(function(c) {
                    var sel = c.value === defaultChain ? ' selected' : '';
                    return '<option value="' + escAttr(c.value) + '"' + sel + '>' + escAttr(c.label) + '</option>';
                }).join('');
                selectorHtml = '<div style="margin-bottom:10px;">'
                    + '<label for="av-sw-sel" style="display:block;font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:#6b7280;margin-bottom:.35rem;">Select network</label>'
                    + '<div style="display:flex;align-items:center;gap:.5rem;">'
                    + '<span id="av-sw-dot" style="display:inline-block;width:9px;height:9px;border-radius:50%;flex-shrink:0;background:' + firstColour + ';transition:background .2s;"></span>'
                    + '<div style="position:relative;flex:1;">'
                    + '<select id="av-sw-sel" name="algovoi_network" form="confirmOrderForm" style="width:100%;padding:.4rem .65rem;background:#0d0e1a;border:1px solid #2a2d3a;'
                    +   'border-radius:7px;color:#f1f2f6;font-size:.85rem;cursor:pointer;'
                    +   'appearance:none;-webkit-appearance:none;outline:none;box-sizing:border-box;transition:border-color .2s;">'
                    + opts
                    + '</select>'
                    + '<span style="position:absolute;right:.7rem;top:50%;transform:translateY(-50%);color:#6b7280;pointer-events:none;font-size:.75rem;">&#9662;</span>'
                    + '</div></div></div>';
            }

            return '<div style="background:#141622;border:1px solid #1f2235;border-radius:8px;'
                + 'padding:10px 14px;color:#e0e0e0;font-family:-apple-system,BlinkMacSystemFont,\'Segoe UI\',sans-serif;'
                + 'max-width:100%;box-sizing:border-box;margin-top:.5rem;">'
                + '<div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:6px;margin-bottom:8px;">'
                + '<div style="display:flex;align-items:center;flex-wrap:wrap;gap:6px;">'
                + '<span style="width:22px;height:22px;border-radius:6px;background:linear-gradient(135deg,#6366f1,#8b5cf6);'
                +   'display:flex;align-items:center;justify-content:center;font-size:12px;flex-shrink:0;">&#9670;</span>'
                + '<strong style="color:#fff;font-size:14px;font-weight:700;">AlgoVoi</strong>'
                + '<span style="font-size:11px;color:#6b7280;border:1px solid #1f2235;border-radius:4px;padding:2px 6px;">' + badgeType + '</span>'
                + '</div>'
                + '<div style="display:flex;flex-wrap:wrap;gap:6px;">' + badge1 + '</div>'
                + '</div>'
                + selectorHtml
                + '<div style="padding-top:.5rem;border-top:1px solid #1f2235;'
                +   'display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.4rem;">'
                + '<span style="font-size:.68rem;color:#4b5563;">Secured by '
                +   '<a href="https://www.algovoi.co.uk" target="_blank" rel="noopener" '
                +      'style="color:#6366f1;text-decoration:none;font-weight:600;">AlgoVoi</a>'
                +   ' &mdash; instant on-chain settlement</span>'
                + '<span style="font-size:.68rem;color:#374151;">No chargebacks &bull; No FX fees</span>'
                + '</div></div>';
        }

        function wireSelect() {
            var sel = document.getElementById('av-sw-sel');
            var dot = document.getElementById('av-sw-dot');
            if (!sel) return;
            sel.addEventListener('change', function() {
                userChain = this.value;  // remember pick across re-renders
                if (dot) dot.style.background = NET_COLOURS[this.value] || '#3b82f6';
            });
        }

        function update() {
            if (rendering) return;

            var checked = document.querySelector('input[name="paymentMethodId"]:checked');
            var pmId    = checked ? checked.value : null;

            // Always remove existing panel before deciding
            var oldPanel = document.getElementById('av-chain-selector');

            if (!pmId) {
                if (oldPanel) oldPanel.remove();
                return;
            }

            var chains = null, isWallet = false;
            if (HOSTED_ID && pmId === HOSTED_ID) { chains = hostedChains; }
            else if (WALLET_ID && pmId === WALLET_ID) { chains = walletChains; isWallet = true; }

            if (!chains || chains.length === 0) {
                // Non-AlgoVoi method selected — hide the panel
                if (oldPanel) oldPanel.remove();
                return;
            }

            // Render fresh panel for AlgoVoi method (preserves userChain via buildPanel)
            rendering = true;
            try {
                if (oldPanel) oldPanel.remove();

                var wrapper = document.createElement('div');
                wrapper.id = 'av-chain-selector';
                wrapper.innerHTML = buildPanel(chains, isWallet);

                var methodDiv = checked.closest('.payment-method');
                if (methodDiv) {
                    methodDiv.appendChild(wrapper);
                    wireSelect();
                }
            } finally {
                setTimeout(function() { rendering = false; }, 50);
            }
        }

        function init() {
            update();

            // Direct change-event listener on payment radios — fires reliably even when
            // changePaymentForm AJAX-resubmits and replaces .payment-method content.
            document.addEventListener('change', function(e) {
                if (e.target && e.target.name === 'paymentMethodId') {
                    setTimeout(update, 80);
                }
            });

            // MutationObserver as a safety net for AJAX response replacing payment-method DOM.
            var target = document.querySelector('.payment-methods') || document.body;
            var debounce;
            new MutationObserver(function() {
                if (rendering) return;
                clearTimeout(debounce);
                debounce = setTimeout(update, 200);
            }).observe(target, { childList: true, subtree: true });
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', init);
        } else {
            init();
        }
    })();
    </script>
{% endblock %}
