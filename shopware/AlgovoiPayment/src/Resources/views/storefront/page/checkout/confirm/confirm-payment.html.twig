{% sw_extends '@Storefront/storefront/page/checkout/confirm/confirm-payment.html.twig' %}

{% block page_checkout_change_payment_form %}
    {{ parent() }}

    {# ── Resolve real payment method UUIDs from handlerIdentifier ─────────── #}
    {% set _hostedHandler = 'AlgovoiPayment\\\\PaymentHandler\\\\AlgovoiHostedPaymentHandler' %}
    {% set _walletHandler = 'AlgovoiPayment\\\\PaymentHandler\\\\AlgovoiWalletPaymentHandler' %}
    {% set _hostedId = '' %}
    {% set _walletId = '' %}
    {% for pm in page.paymentMethods %}
        {% if pm.handlerIdentifier == _hostedHandler %}{% set _hostedId = pm.id %}{% endif %}
        {% if pm.handlerIdentifier == _walletHandler %}{% set _walletId = pm.id %}{% endif %}
    {% endfor %}

    {# ── Build enabled-networks list from system config ─────────────────────── #}
    {% set _allNetworks = {
        'algorand_mainnet': 'Algorand — USDC',
        'voi_mainnet':      'VOI — aUSDC',
        'hedera_mainnet':   'Hedera — USDC',
        'stellar_mainnet':  'Stellar — USDC',
        'base_mainnet':     'Base — USDC',
        'solana_mainnet':   'Solana — USDC',
        'tempo_mainnet':    'Tempo — USDCe'
    } %}
    {% set _cfgEnabled = config('AlgovoiPayment.config.enabledNetworks') %}
    {% if _cfgEnabled is iterable and _cfgEnabled is not empty %}
        {% set _enabledKeys = _cfgEnabled %}
    {% else %}
        {% set _enabledKeys = _allNetworks|keys %}
    {% endif %}
    {# wallet (extension) stays AVM-only regardless of config #}
    {% set _walletKeys = ['algorand_mainnet', 'voi_mainnet'] %}

    {# Serialise to JSON for the inline script #}
    {% set _hostedJson = [] %}
    {% for k in _enabledKeys %}
        {% if _allNetworks[k] is defined %}
            {% set _hostedJson = _hostedJson|merge([{'value': k, 'label': _allNetworks[k]}]) %}
        {% endif %}
    {% endfor %}
    {% set _walletJson = [] %}
    {% for k in _walletKeys %}
        {% set _walletJson = _walletJson|merge([{'value': k, 'label': _allNetworks[k]}]) %}
    {% endfor %}

    <script>
    (function() {
        var HOSTED_ID = '{{ _hostedId|e('js') }}';
        var WALLET_ID = '{{ _walletId|e('js') }}';

        var hostedChains = {{ _hostedJson|json_encode|raw }};
        var walletChains = {{ _walletJson|json_encode|raw }};

        var NET_COLOURS = {
            algorand_mainnet: '#3b82f6',
            voi_mainnet:      '#8b5cf6',
            hedera_mainnet:   '#10b981',
            stellar_mainnet:  '#06b6d4',
            base_mainnet:     '#2563eb',
            solana_mainnet:   '#9333ea',
            tempo_mainnet:    '#f59e0b'
        };

        function getHiddenInput() {
            var form = document.getElementById('confirmOrderForm');
            if (!form) return null;
            var inp = form.querySelector('input[name="algovoi_network"]');
            if (!inp) {
                inp = document.createElement('input');
                inp.type  = 'hidden';
                inp.name  = 'algovoi_network';
                inp.value = 'algorand_mainnet';
                form.appendChild(inp);
            }
            return inp;
        }

        function buildPanel(chains, isWallet) {
            var badge1 = isWallet
                ? '<span style="font-size:10px;background:rgba(59,130,246,.1);color:#60a5fa;border-radius:4px;padding:2px 7px;font-weight:600;">In-page</span>'
                + '<span style="font-size:10px;background:rgba(16,185,129,.1);color:#34d399;border-radius:4px;padding:2px 7px;font-weight:600;">No redirect</span>'
                : '<span style="font-size:10px;background:rgba(99,102,241,.1);color:#818cf8;border-radius:4px;padding:2px 7px;font-weight:600;">Secure checkout</span>'
                + '<span style="font-size:10px;background:rgba(245,158,11,.1);color:#fbbf24;border-radius:4px;padding:2px 7px;font-weight:600;">Redirect</span>';
            var badgeType = isWallet ? 'Extension' : 'Hosted';
            var desc = isWallet
                ? 'Pay instantly with USDC (Algorand) or aUSDC (VOI) directly from your AlgoVoi browser extension.'
                : 'Pay with USDC / aUSDC / USDCe stablecoins via hosted checkout. You will be redirected after confirming your order.';

            var firstColour = NET_COLOURS[chains[0].value] || '#3b82f6';

            var selectorHtml = '';
            if (chains.length === 1) {
                selectorHtml = '<div style="margin-bottom:14px;display:flex;align-items:center;gap:.6rem;">'
                    + '<span id="av-sw-dot" style="display:inline-block;width:10px;height:10px;border-radius:50%;flex-shrink:0;background:' + firstColour + ';"></span>'
                    + '<span style="font-size:13px;color:#e0e0e0;">' + chains[0].label + '</span>'
                    + '</div>';
            } else {
                var opts = chains.map(function(c) {
                    return '<option value="' + c.value + '">' + c.label + '</option>';
                }).join('');
                selectorHtml = '<div style="margin-bottom:16px;">'
                    + '<label style="display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:#6b7280;margin-bottom:6px;">Select network</label>'
                    + '<div style="display:flex;align-items:center;gap:.6rem;">'
                    + '<span id="av-sw-dot" style="display:inline-block;width:10px;height:10px;border-radius:50%;flex-shrink:0;background:' + firstColour + ';transition:background .2s;"></span>'
                    + '<div style="position:relative;flex:1;">'
                    + '<select id="av-sw-sel" style="width:100%;padding:.5rem .75rem;background:#0d0e1a;border:1px solid #2a2d3a;'
                    +   'border-radius:7px;color:#f1f2f6;font-size:.88rem;cursor:pointer;'
                    +   'appearance:none;-webkit-appearance:none;outline:none;transition:border-color .2s;"'
                    +   ' onfocus="this.style.borderColor=\'#6366f1\'" onblur="this.style.borderColor=\'#2a2d3a\'">'
                    + opts
                    + '</select>'
                    + '<span style="position:absolute;right:.7rem;top:50%;transform:translateY(-50%);color:#6b7280;pointer-events:none;font-size:.75rem;">&#9662;</span>'
                    + '</div></div></div>';
            }

            return '<div style="background:#141622;border:1px solid #1f2235;border-radius:10px;'
                + 'padding:16px 20px;color:#e0e0e0;font-family:-apple-system,BlinkMacSystemFont,\'Segoe UI\',sans-serif;margin-top:10px;">'
                + '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;">'
                + '<div style="display:flex;align-items:center;gap:10px;">'
                + '<span style="width:26px;height:26px;border-radius:7px;background:linear-gradient(135deg,#6366f1,#8b5cf6);'
                +   'display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0;">&#9670;</span>'
                + '<strong style="color:#fff;font-size:14px;font-weight:700;">AlgoVoi</strong>'
                + '<span style="font-size:11px;color:#6b7280;border:1px solid #1f2235;border-radius:4px;padding:2px 7px;">' + badgeType + '</span>'
                + '</div>'
                + '<div style="display:flex;gap:6px;">' + badge1 + '</div>'
                + '</div>'
                + '<p style="margin:0 0 12px;font-size:12px;color:#9ca3af;line-height:1.6;">' + desc + '</p>'
                + selectorHtml
                + '<div style="padding-top:.6rem;border-top:1px solid #1f2235;'
                +   'display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.4rem;">'
                + '<span style="font-size:.7rem;color:#4b5563;">Secured by '
                +   '<a href="https://www.algovoi.co.uk" target="_blank" rel="noopener" '
                +      'style="color:#6366f1;text-decoration:none;font-weight:600;">AlgoVoi</a>'
                +   ' &mdash; instant on-chain settlement</span>'
                + '<span style="font-size:.7rem;color:#374151;">No chargebacks &bull; No FX fees</span>'
                + '</div></div>';
        }

        function wireSelect(chains) {
            var sel = document.getElementById('av-sw-sel');
            var dot = document.getElementById('av-sw-dot');
            var inp = getHiddenInput();
            if (!sel) {
                if (inp && chains.length === 1) inp.value = chains[0].value;
                return;
            }
            sel.addEventListener('change', function() {
                if (inp) inp.value = this.value;
                if (dot) dot.style.background = NET_COLOURS[this.value] || '#3b82f6';
            });
            if (inp) inp.value = chains[0].value;
        }

        function update() {
            var old = document.getElementById('av-chain-selector');
            if (old) old.remove();

            var checked = document.querySelector('input[name="paymentMethodId"]:checked');
            if (!checked) return;
            var val = checked.value;

            var chains = null, isWallet = false;
            if (HOSTED_ID && val === HOSTED_ID) { chains = hostedChains; }
            else if (WALLET_ID && val === WALLET_ID) { chains = walletChains; isWallet = true; }
            if (!chains || chains.length === 0) return;

            var wrapper = document.createElement('div');
            wrapper.id = 'av-chain-selector';
            wrapper.innerHTML = buildPanel(chains, isWallet);

            var methodDiv = checked.closest('.payment-method');
            if (methodDiv) {
                methodDiv.appendChild(wrapper);
                wireSelect(chains);
            }
        }

        function init() {
            update();
            var target = document.querySelector('.payment-methods') || document.body;
            new MutationObserver(function() { setTimeout(update, 300); })
                .observe(target, { childList: true, subtree: true });
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', init);
        } else {
            init();
        }
    })();
    </script>
{% endblock %}
