<?xml version="1.0" ?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>

        <service id="AlgovoiPayment\Helper\ApiHelper">
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
        </service>

        <service id="AlgovoiPayment\PaymentHandler\AlgovoiHostedPaymentHandler">
            <argument type="service" id="AlgovoiPayment\Helper\ApiHelper"/>
            <argument type="service" id="order_transaction.repository"/>
            <argument type="service" id="order.repository"/>
            <tag name="shopware.payment.method"/>
        </service>

        <service id="AlgovoiPayment\PaymentHandler\AlgovoiWalletPaymentHandler">
            <argument type="service" id="AlgovoiPayment\Helper\ApiHelper"/>
            <argument type="service" id="order_transaction.repository"/>
            <argument type="service" id="router"/>
            <tag name="shopware.payment.method"/>
        </service>

        <service id="AlgovoiPayment\Controller\AlgovoiWalletController" public="true">
            <argument type="service" id="AlgovoiPayment\Helper\ApiHelper"/>
            <argument type="service" id="order_transaction.repository"/>
            <argument type="service" id="Shopware\Core\Checkout\Order\Aggregate\OrderTransaction\OrderTransactionStateHandler"/>
            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
        </service>

        <service id="AlgovoiPayment\Controller\AlgovoiWebhookController" public="true">
            <argument type="service" id="AlgovoiPayment\Helper\ApiHelper"/>
            <argument type="service" id="order.repository"/>
            <argument type="service" id="Shopware\Core\Checkout\Order\Aggregate\OrderTransaction\OrderTransactionStateHandler"/>
            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
        </service>

    </services>
</container>
