<?xml version="1.0" encoding="UTF-8"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/shopware/shopware/trunk/src/Core/System/SystemConfig/Schema/config.xsd">
    <card>
        <title>AlgoVoi Payment Settings</title>
        <title lang="de-DE">AlgoVoi Zahlungseinstellungen</title>

        <input-field>
            <name>apiBaseUrl</name>
            <defaultValue>https://api1.ilovechicken.co.uk</defaultValue>
            <label>API Base URL</label>
            <label lang="de-DE">API-Basis-URL</label>
        </input-field>

        <input-field>
            <name>tenantId</name>
            <label>Tenant ID</label>
        </input-field>

        <input-field type="password">
            <name>apiKey</name>
            <label>API Key</label>
            <label lang="de-DE">API-Schlüssel</label>
        </input-field>

        <input-field type="password">
            <name>webhookSecret</name>
            <label>Webhook Secret</label>
        </input-field>

        <input-field type="single-select">
            <name>network</name>
            <defaultValue>algorand_mainnet</defaultValue>
            <label>Default / Fallback Network</label>
            <label lang="de-DE">Standard-Netzwerk</label>
            <options>
                <option><id>algorand_mainnet</id><name>Algorand Mainnet (USDC)</name></option>
                <option><id>voi_mainnet</id><name>VOI Mainnet (aUSDC)</name></option>
                <option><id>hedera_mainnet</id><name>Hedera Mainnet (USDC)</name></option>
                <option><id>stellar_mainnet</id><name>Stellar Mainnet (USDC)</name></option>
                <option><id>base_mainnet</id><name>Base Mainnet (USDC)</name></option>
                <option><id>solana_mainnet</id><name>Solana Mainnet (USDC)</name></option>
                <option><id>tempo_mainnet</id><name>Tempo Mainnet (USDCe)</name></option>
            </options>
        </input-field>

        <input-field type="multi-select">
            <name>enabledNetworks</name>
            <label>Enabled Networks</label>
            <label lang="de-DE">Aktivierte Netzwerke</label>
            <helpText>Networks shown at checkout. Select one to hide the selector and use it automatically.</helpText>
            <options>
                <option><id>algorand_mainnet</id><name>Algorand — USDC</name></option>
                <option><id>voi_mainnet</id><name>VOI — aUSDC</name></option>
                <option><id>hedera_mainnet</id><name>Hedera — USDC</name></option>
                <option><id>stellar_mainnet</id><name>Stellar — USDC</name></option>
                <option><id>base_mainnet</id><name>Base — USDC</name></option>
                <option><id>solana_mainnet</id><name>Solana — USDC</name></option>
                <option><id>tempo_mainnet</id><name>Tempo — USDCe</name></option>
            </options>
        </input-field>
    </card>
</config>
